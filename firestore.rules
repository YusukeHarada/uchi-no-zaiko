rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMember(hid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/households/$(hid))
        && request.auth.uid in get(/databases/$(database)/documents/households/$(hid)).data.memberUids;
    }

    // 有効な招待コードで参加しようとしているか
    function isJoiningWithCode() {
      let uid = request.auth.uid;
      return isSignedIn()
        // まだメンバーでない
        && !(uid in resource.data.memberUids)
        // 自分を追加しようとしている
        && uid in request.resource.data.memberUids
        // 既存メンバーを削除していない
        && request.resource.data.memberUids.hasAll(resource.data.memberUids)
        // 有効な招待コードが存在する
        && resource.data.inviteCode != null
        && resource.data.inviteCodeExpiresAt > request.time
        // オーナーが変わっていない
        && request.resource.data.ownerUid == resource.data.ownerUid;
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid;
      allow update: if isSelf(uid)
        && request.resource.data.uid == uid;
      allow delete: if false;
    }

    // 招待コードコレクション（認証済みユーザーなら誰でも検索可）
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && isMember(request.resource.data.householdId);
      allow delete: if isSignedIn()
        && isMember(resource.data.householdId);
    }

    match /households/{hid} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.memberUids;

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      allow update: if isSignedIn()
        && (
          // 既存メンバーによる更新
          (request.auth.uid in resource.data.memberUids
            && request.resource.data.ownerUid == resource.data.ownerUid)
          // 招待コードを使った参加
          || isJoiningWithCode()
        );

      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;

      match /items/{itemId} {
        allow read, write: if isMember(hid);
      }

      match /shoppingList/{itemId} {
        allow read, write: if isMember(hid);
      }

      match /categories/{categoryId} {
        allow read, write: if isMember(hid);
      }
    }
  }
}
